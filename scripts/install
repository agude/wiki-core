#!/usr/bin/env bash
#
# install - Wire hooks and skills into the system.
#
# Creates symlinks for coat-tree hooks and Claude Code skills.
# Idempotent — safe to re-run after updates.
#
# Usage:
#   install
#
# Locations:
#   Hooks:  ~/.config/coat-tree/hooks.d/<event>/020.wiki
#   Skills: ~/.claude/skills/<name>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd -P)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd -P)"

COAT_TREE_HOOKS="${XDG_CONFIG_HOME:-$HOME/.config}/coat-tree/hooks.d"
SKILLS_DIR="$HOME/.claude/skills"
HOOK_PREFIX="020.wiki"

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            awk 'NR==1{next} /^$/{exit} {sub(/^# ?/,""); print}' "$0"
            exit 0
            ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

# --- Cleanup: remove every prior symlink pointing into this repo ---
#
# Anything currently linking into $REPO_ROOT was created by a previous
# run of this install. Whichever entries we still want will be recreated
# below; whichever we don't (renamed schemes, removed hooks) just stay
# gone. Clean slate is simpler than tracking which names are stale.

removed=0
for link in "${COAT_TREE_HOOKS}"/*/* "${SKILLS_DIR}"/*; do
    [[ -L "$link" ]] || continue
    target="$(readlink "$link")"
    case "$target" in
        "${REPO_ROOT}/"*)
            rm "$link"
            removed=$((removed + 1))
            ;;
    esac
done
if (( removed > 0 )); then
    echo "Removed $removed prior symlink(s)."
fi

# --- Hooks ---

HOOKS=(
    "SessionStart:session-start"
    "PreToolUse:pretool-allow"
)

echo "Installing hooks..."
for pair in "${HOOKS[@]}"; do
    event="${pair%%:*}"
    script="${pair##*:}"
    mkdir -p "${COAT_TREE_HOOKS}/${event}"
    ln -sf "${SCRIPT_DIR}/${script}" "${COAT_TREE_HOOKS}/${event}/${HOOK_PREFIX}"
    echo "  ${event}/${HOOK_PREFIX}"
done

# --- Skills ---

echo "Installing skills..."
mkdir -p "$SKILLS_DIR"
for skill_dir in "$REPO_ROOT/skills/"*/; do
    [[ -d "$skill_dir" ]] || continue
    name="$(basename "$skill_dir")"
    ln -sfn "$skill_dir" "${SKILLS_DIR}/${name}"
    echo "  ${name}"
done

echo "Done."
