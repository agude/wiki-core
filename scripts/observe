#!/usr/bin/env bash
#
# observe - Record a new observation in the wiki inbox.
#
# Creates a timestamped markdown file in inbox/ and auto-commits it.
# The body can come from --body or stdin.
#
# Usage:
#   observe --title "..." [--body "..."]
#   observe --title "..." < file.txt
#   echo "stuff" | observe --title "..."
#
# Options:
#   --title TEXT   Observation title (required)
#   --body TEXT    Observation body. If omitted, reads from stdin.
#   --source TEXT  Where this came from (default: "session")
#   --no-commit    Skip the auto-commit
#
# Examples:
#   observe --title "DNS caching issue" --body "Discovered that..."
#   observe --title "Meeting notes" < /tmp/notes.txt
#   observe --title "Quick note" --body "Remember to check X"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
source "$SCRIPT_DIR/_lib.sh"
INBOX_DIR="$CONTENT_DIR/inbox"

TITLE=""
BODY=""
SOURCE="session"
DO_COMMIT=true

while [[ $# -gt 0 ]]; do
    case "$1" in
        --title)     need_arg "$1" $#; TITLE="$2"; shift 2 ;;
        --body)      need_arg "$1" $#; BODY="$2"; shift 2 ;;
        --source)    need_arg "$1" $#; SOURCE="$2"; shift 2 ;;
        --no-commit) DO_COMMIT=false; shift ;;
        -h|--help)
            sed -n '2,/^$/{ s/^# //; p }' "$0"
            exit 0
            ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

# Hard guard: only write if observation is explicitly enabled
if [[ "${WIKI_OBSERVE:-}" != "1" ]]; then
    echo "Observation disabled (WIKI_OBSERVE is not 1)" >&2
    exit 0
fi

if [[ -z "$TITLE" ]]; then
    echo "Error: --title is required" >&2
    exit 1
fi

# Read body from stdin if not provided via --body
if [[ -z "$BODY" ]]; then
    if [[ ! -t 0 ]]; then
        BODY="$(cat)"
    else
        echo "Error: --body not provided and stdin is a terminal" >&2
        exit 1
    fi
fi

# Generate filename: YYYYMMDDTHHMMSS-<4 random chars>.md
timestamp="$(date -u +%Y%m%dT%H%M%S)"
suffix="$(head -c 2 /dev/urandom | xxd -p | head -c 4)"
filename="${timestamp}-${suffix}.md"
filepath="$INBOX_DIR/$filename"

# Write the observation
safe_title="$(yaml_escape "$TITLE")"
cat > "$filepath" <<EOF
---
title: "$safe_title"
source: $SOURCE
created: $(date -u +%Y-%m-%dT%H:%M:%SZ)
---

$BODY
EOF

echo "Wrote: inbox/$filename"

# Auto-commit
if [[ "$DO_COMMIT" == true ]]; then
    locked_commit "Observe: $TITLE" "inbox/$filename"
fi
