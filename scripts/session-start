#!/usr/bin/env bash
#
# session-start - SessionStart hook for the wiki.
#
# Called by Claude Code's SessionStart hook via coat-tree.
# Outputs the wiki CLAUDE.md to stdout (injected into context).
#
# Input: JSON on stdin with session_id, transcript_path, etc.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Read hook input (must consume stdin before any early exit)
INPUT="$(cat)"

# Output CLAUDE.md to inject into context
if [[ -f "$REPO_ROOT/CLAUDE.md" ]]; then
    cat "$REPO_ROOT/CLAUDE.md"
fi
